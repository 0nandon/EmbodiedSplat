ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -pthread -B /data/sjlee/anaconda3/envs/drsplat/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /data/sjlee/anaconda3/envs/drsplat/include -I/data/sjlee/anaconda3/envs/drsplat/include -fPIC -O2 -isystem /data/sjlee/anaconda3/envs/drsplat/include -fPIC -I/data/sjlee/anaconda3/envs/drsplat/lib/python3.9/site-packages/torch/include -I/data/sjlee/anaconda3/envs/drsplat/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/data/sjlee/anaconda3/envs/drsplat/lib/python3.9/site-packages/torch/include/TH -I/data/sjlee/anaconda3/envs/drsplat/lib/python3.9/site-packages/torch/include/THC -I/usr/local/cuda/include -I/data/sjlee/anaconda3/envs/drsplat/include/python3.9 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -I/data/sjlee/anaconda3/envs/drsplat/lib/python3.9/site-packages/torch/include -I/data/sjlee/anaconda3/envs/drsplat/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/data/sjlee/anaconda3/envs/drsplat/lib/python3.9/site-packages/torch/include/TH -I/data/sjlee/anaconda3/envs/drsplat/lib/python3.9/site-packages/torch/include/THC -I/usr/local/cuda/include -I/data/sjlee/anaconda3/envs/drsplat/include/python3.9 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -Xcompiler -fno-gnu-unique -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_89,code=compute_89 -gencode=arch=compute_89,code=sm_89 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





build /data/sjlee/freesplatpp/main/src/third_party/localagg/build/temp.linux-x86_64-cpython-39/ext.o: compile /data/sjlee/freesplatpp/main/src/third_party/localagg/ext.cpp
build /data/sjlee/freesplatpp/main/src/third_party/localagg/build/temp.linux-x86_64-cpython-39/local_aggregate.o: cuda_compile /data/sjlee/freesplatpp/main/src/third_party/localagg/local_aggregate.cu
build /data/sjlee/freesplatpp/main/src/third_party/localagg/build/temp.linux-x86_64-cpython-39/src/aggregator_impl.o: cuda_compile /data/sjlee/freesplatpp/main/src/third_party/localagg/src/aggregator_impl.cu
build /data/sjlee/freesplatpp/main/src/third_party/localagg/build/temp.linux-x86_64-cpython-39/src/backward.o: cuda_compile /data/sjlee/freesplatpp/main/src/third_party/localagg/src/backward.cu
build /data/sjlee/freesplatpp/main/src/third_party/localagg/build/temp.linux-x86_64-cpython-39/src/forward.o: cuda_compile /data/sjlee/freesplatpp/main/src/third_party/localagg/src/forward.cu






